datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED
}

enum ItemStatus {
  RECEIVED
  PREPARING
  READY
  COLLECTED
}

enum OrderType {
  DINE_IN
  COLLECTION
  DELIVERY
}

model Vendor {
  id              String      @id @default(cuid())
  name            String
  cuisine         String
  imageUrl        String?
  collectionPoint String?     // e.g., "Station 1", "Counter A"
  menuItems       MenuItem[]
  orderItems      OrderItem[]
  orders          Order[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  price       Float
  category    String
  description String?
  region      String?
  allergens   String[]
  dietary     String[]
  isVegan     Boolean     @default(false)
  available   Boolean     @default(true)
  vendorId    String
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Session {
  id        String   @id @default(cuid())
  vendorId  String?
  location  String?
  cart      Json?
  createdAt DateTime @default(now())
}

model Order {
  id                  String      @id @default(cuid())
  orderNumber         Int?
  orderType           OrderType   @default(DINE_IN)
  status              OrderStatus @default(PENDING)
  totalAmount         Float
  paymentId           String?
  groupId             String?
  tableNumber         String?
  deliveryAddress     String?
  deliveryFee         Float       @default(0.0)
  customerPhone       String?
  customerName        String?
  specialInstructions String?
  vendorId            String?
  vendor              Vendor?     @relation(fields: [vendorId], references: [id])
  items               OrderItem[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([groupId])
  @@index([status])
  @@index([vendorId])
  @@index([orderType])
}

model OrderItem {
  id         String     @id @default(cuid())
  orderId    String
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id])
  vendorId   String
  vendor     Vendor     @relation(fields: [vendorId], references: [id])
  quantity   Int        @default(1)
  price      Float
  guestName  String?
  status     ItemStatus @default(RECEIVED)

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
}
