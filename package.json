{
  "name": "event-ordering-system",
  "version": "1.0.0",
  "description": "QR-based multi-vendor food hall ordering system with AI concierge, group ordering, and KDS",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon server/index.js",
    "dev:frontend": "vite",
    "build": "prisma generate && vite build --mode production",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "release": "([ -z \"$DATABASE_URL\" ] || npm run db:deploy) && npm run start:prod",
    "prod": "npm run build && npm run start:prod",
    "test:prod": "npm run build && npm run start:prod",
    "postinstall": "[ -f prisma/schema.prisma ] && prisma generate || true",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "qr": "node scripts/generate-qr.js",
    "health": "curl -s http://localhost:3000/api/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d)))\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@railway/cli": "^4.30.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^13.11.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "vite": "^5.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
