# ─────────────────────────────────────────────────────────────────
#  Food Hall Event Ordering System — Environment Variables
# ─────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3001

# Set this to your live domain — used for QR codes and logs
# Examples:
#   https://food-hall.railway.app
#   https://food-hall.onrender.com
#   https://yourevent.com
PUBLIC_URL=https://your-app.railway.app

# ── Database (PostgreSQL via Neon, Supabase, or Railway) ──────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Vite Frontend ─────────────────────────────────────────────────
# Dev: point to backend port
# Production (single server): leave empty for same-origin
VITE_API_URL=http://localhost:3001

# Public URL baked into the built frontend (for QR default)
VITE_PUBLIC_URL=https://your-app.railway.app

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of origins allowed in dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: SMS Notifications (Twilio) ──────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155551234

# ── Optional: Payment Processing (Stripe) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Optional: KDS Access Secret ───────────────────────────────────
# Staff use ?key=<value> to access the Kitchen Display (/kds view)
KDS_SECRET=change-me-to-something-secret
